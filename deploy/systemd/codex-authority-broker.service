[Unit]
Description=Codex authority broker
After=local-fs.target

[Service]
Type=simple
ExecStart=/usr/local/bin/codex-authority-broker
Restart=on-failure
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run

[Install]
WantedBy=multi-user.target
