#!/usr/bin/python3
import hashlib
import json
import os
import stat
import sys
from pathlib import Path

here = Path(__file__).resolve().parent
sys.dont_write_bytecode = True
def strict_pairs(pairs):
    value = {}
    for key, item in pairs:
        if key in value:
            raise ValueError("duplicate")
        value[key] = item
    return value

recovery_dirs = {
    Path("/var/lib/codex-authority-recovery"),
    Path("/var/lib/codex-authority-recovery.completed"),
}
if here in recovery_dirs:
    state_path = Path("/var/lib/codex-authority-installer/state.json")
    if not state_path.exists():
        state_path = here / "state.json"
    if not state_path.exists():
        product_paths = (
            "/run/codex-authority.sock", "/etc/codex-authority", "/etc/pam.d/codex-authority",
            "/etc/sudoers.d/codex-authority", "/etc/systemd/system/codex-authority-broker.service",
            "/var/lib/codex-authority-installer", "/usr/local/lib/codex-authority",
            "/usr/local/bin/codex-authority", "/usr/local/bin/codex-authority-broker",
            "/usr/local/bin/codex-authority-sudo", "/usr/local/sbin/codex-authority-admin",
            "/usr/local/sbin/codex-authority-verify", "/usr/local/sbin/codex-authority-recover",
            "/usr/local/sbin/codex-authority-uninstall",
        )
        if any(Path(name).exists() or Path(name).is_symlink() for name in product_paths):
            raise SystemExit("request denied")
        metadata = here.lstat()
        if not stat.S_ISDIR(metadata.st_mode) or metadata.st_uid != 0 or stat.S_IMODE(metadata.st_mode) != 0o700:
            raise SystemExit("request denied")
        allowed = {"recover", "codex_authority_installer.py", "SHA256SUMS"}
        if any(path.name not in allowed or not path.is_file() or path.is_symlink() for path in here.iterdir()):
            raise SystemExit("request denied")
        modes = {"recover": 0o500, "codex_authority_installer.py": 0o400, "SHA256SUMS": 0o400}
        for path in here.iterdir():
            metadata = path.lstat()
            if metadata.st_uid != 0 or stat.S_IMODE(metadata.st_mode) != modes[path.name]:
                raise SystemExit("request denied")
        for name in ("codex_authority_installer.py", "SHA256SUMS"):
            try:
                (here / name).unlink()
            except FileNotFoundError:
                pass
        Path(__file__).unlink()
        here.rmdir()
        print("recover complete")
        raise SystemExit(0)
    sums_path = here / "SHA256SUMS"
    core_path = here / "codex_authority_installer.py"
    for path, mode in ((state_path, 0o600), (sums_path, 0o400), (core_path, 0o400), (Path(__file__), 0o500)):
        metadata = path.lstat()
        if not stat.S_ISREG(metadata.st_mode) or metadata.st_uid != 0 or stat.S_IMODE(metadata.st_mode) != mode or metadata.st_size > 131072:
            raise SystemExit("request denied")
    state = json.loads(state_path.read_bytes(), object_pairs_hook=strict_pairs)
    sums = sums_path.read_bytes()
    if hashlib.sha256(sums).hexdigest() != state.get("artifact_digest"):
        raise SystemExit("request denied")
    expected = {}
    for line in sums.decode("ascii").splitlines():
        digest, name = line.split("  ", 1)
        if name in expected:
            raise SystemExit("request denied")
        expected[name] = digest
    for path, name in ((Path(__file__), "install/codex-authority-recover"), (core_path, "install/codex_authority_installer.py")):
        if hashlib.sha256(path.read_bytes()).hexdigest() != expected.get(name):
            raise SystemExit("request denied")
sys.path.insert(0, str(here))
sys.path.append("/usr/local/lib/codex-authority")
from codex_authority_installer import cli

raise SystemExit(cli("recover"))
